{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Whisper",
  "version": "0.1.0",
  "identifier": "com.jiahaochen.local-whisper",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Local Whisper",
        "width": 880,
        "height": 560,
        "minWidth": 720,
        "minHeight": 480,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "resources": [
      "../python-sidecar/server.py",
      "../python-sidecar/asr_engine.py",
      "../python-sidecar/llm_engine.py",
      "../python-sidecar/model_manager.py",
      "../python-sidecar/requirements.txt"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    }
  }
}
